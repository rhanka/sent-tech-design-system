{
  "theme": "dsfr",
  "label": "Système de Design de l'État",
  "source": {
    "kind": "public",
    "url": "https://www.systeme-de-design.gouv.fr/",
    "package": "@gouvfr/dsfr@1.14.4",
    "notes": [
      "The DSFR site blocks automated browsing behind Cloudflare, so the package and existing DSFR public guidance are used for token/source grounding.",
      "Reference shape: République Française brand block, two-level white header, horizontal nav with blue underline, left side menu with blue active block and breadcrumb."
    ]
  },
  "assets": {
    "republiqueFrancaise": {
      "path": "assets/logo-rf-marianne.svg",
      "targetSize": "about 80px high in desktop header",
      "usage": "Use as the brand block on the left of the header. Text alternative belongs on the home link."
    }
  },
  "layout": {
    "header": {
      "background": "#ffffff",
      "foreground": "#161616",
      "borderBottom": "1px solid #dddddd",
      "minHeight": "80px",
      "maxWidth": "78rem",
      "padding": "12px 24px",
      "brand": {
        "display": "inline-flex",
        "gap": "16px",
        "logoHeight": "64-80px",
        "republicText": {
          "fontSize": "12px",
          "fontWeight": 700,
          "letterSpacing": "0.04em",
          "lineHeight": 1.2,
          "textTransform": "uppercase"
        },
        "title": {
          "fontSize": "13px",
          "fontWeight": 600,
          "lineHeight": 1.3,
          "color": "#000091"
        }
      },
      "tools": {
        "alignment": "right",
        "links": ["Être tenu informé", "version", "compare", "theme", "locale"],
        "search": {
          "width": "max 28rem",
          "height": "40px",
          "inputBorder": "1px solid #3a3a3a",
          "buttonBackground": "#000091",
          "buttonColor": "#ffffff"
        }
      }
    },
    "headerNav": {
      "background": "#ffffff",
      "borderBottom": "1px solid #dddddd",
      "shadow": "0 1px 4px rgb(0 0 145 / 0.06)",
      "maxWidth": "78rem",
      "itemMinHeight": "48px",
      "itemPaddingInline": "16px",
      "fontSize": "15px",
      "inactiveColor": "#161616",
      "hoverBackground": "#f6f6f6",
      "activeColor": "#000091",
      "activeFontWeight": 700,
      "activeIndicator": {
        "side": "bottom",
        "height": "3px",
        "color": "#000091"
      }
    },
    "sidebar": {
      "width": "17rem",
      "background": "#ffffff",
      "borderRight": "1px solid #dddddd",
      "top": "10rem",
      "item": {
        "minHeight": "44px",
        "padding": "8px 16px",
        "fontSize": "14px",
        "lineHeight": 1.4,
        "color": "#161616",
        "hoverBackground": "#f6f6f6",
        "activeBackground": "#e3e3fd",
        "activeColor": "#000091",
        "activeFontWeight": 700,
        "activeIndicator": {
          "side": "left",
          "width": "4px",
          "color": "#000091"
        }
      },
      "group": {
        "summaryMinHeight": "36px",
        "summaryFontSize": "11.5px",
        "summaryFontWeight": 700,
        "summaryLetterSpacing": "0.06em",
        "summaryTextTransform": "uppercase",
        "subItemMinHeight": "36px",
        "subItemPaddingLeft": "32px"
      }
    },
    "breadcrumb": {
      "presence": "required above page content",
      "separator": "/",
      "fontSize": "14px",
      "linkColor": "#000091",
      "currentColor": "#161616",
      "marginBottom": "24px"
    }
  },
  "implementationTargets": [
    "apps/docs/src/lib/chrome/ChromeDsfr.svelte logo placeholder",
    "apps/docs/static/chrome/dsfr/logo-rf.svg placeholder"
  ]
}
